# =============================================================================
# Kobae Landing — Environment Variables
# Copy this file to .env.local and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# API
# URL of the kobae backend (no trailing slash)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# Signup Passcode Gate
# Controls access to the signup flow with a simple passcode
# -----------------------------------------------------------------------------
# Set to "true" to enable passcode gate, any other value or omit to disable
NEXT_PUBLIC_SIGNUP_PASSCODE_ENABLED=true
# 6-digit numeric passcode for signup access
NEXT_PUBLIC_SIGNUP_PASSCODE=123456

# -----------------------------------------------------------------------------
# Waitlist — Google Sheets Integration
# Service account credentials used by the /api/waitlist route to append rows.
# -----------------------------------------------------------------------------
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SHEETS_CLIENT_EMAIL=your_service_account@your_project.iam.gserviceaccount.com
# Newlines in the key must be escaped as \n (the API route handles un-escaping)
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
